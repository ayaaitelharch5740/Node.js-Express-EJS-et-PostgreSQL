<%- include('../../partials/header') %>

<nav class="breadcrumb">
  <a href="/">Accueil</a><span class="breadcrumb-sep">›</span>
  <a href="/livres">Livres</a><span class="breadcrumb-sep">›</span>
  <span>Ajouter</span>
</nav>

<div class="page-header">
  <h1>Ajouter un livre</h1>
</div>

<% if (typeof errors !== 'undefined' && errors.length > 0) { %>
  <div class="alert alert-error">⚠️ <%= errors.join(' ') %></div>
<% } %>

<div class="form-card">
  <form action="/livres/ajouter" method="POST">
    <div class="form-group">
      <label class="form-label" for="titre">Titre *</label>
      <input class="form-control" type="text" id="titre" name="titre"
             value="<%= livre.titre || '' %>" required>
    </div>

    <div class="form-group">
      <label class="form-label" for="auteur_id">Auteur *</label>
      <select class="form-control" id="auteur_id" name="auteur_id" required>
        <option value="">— Sélectionner un auteur —</option>
        <% auteurs.forEach(a => { %>
          <option value="<%= a.id %>" <%= livre.auteur_id == a.id ? 'selected' : '' %>>
            <%= a.prenom %> <%= a.nom %>
          </option>
        <% }) %>
      </select>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
      <div class="form-group">
        <label class="form-label" for="annee_publication">Année de publication</label>
        <input class="form-control" type="number" id="annee_publication" name="annee_publication"
               min="1000" max="<%= new Date().getFullYear() %>"
               value="<%= livre.annee_publication || '' %>">
      </div>
      <div class="form-group">
        <label class="form-label" for="genre">Genre</label>
        <input class="form-control" type="text" id="genre" name="genre"
               value="<%= livre.genre || '' %>" placeholder="Roman, Fantasy, Policier…">
      </div>
    </div>

    <div class="form-group">
      <label class="form-label" for="isbn">ISBN</label>
      <input class="form-control" type="text" id="isbn" name="isbn"
             value="<%= livre.isbn || '' %>" placeholder="9782070643028">
    </div>

    <div class="form-group">
      <label class="form-label" for="resume">Résumé</label>
      <textarea class="form-control" id="resume" name="resume" rows="4"><%= livre.resume || '' %></textarea>
    </div>

    <div class="form-group">
      <label class="form-check">
        <input type="checkbox" name="disponible" checked>
        Disponible à l'emprunt
      </label>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-gold">✓ Enregistrer</button>
      <a href="/livres" class="btn btn-outline">Annuler</a>
    </div>
  </form>
</div>

<%- include('../../partials/footer') %>