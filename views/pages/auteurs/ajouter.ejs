<%- include('../../partials/header') %>

<nav class="breadcrumb">
  <a href="/">Accueil</a><span class="breadcrumb-sep">›</span>
  <a href="/auteurs">Auteurs</a><span class="breadcrumb-sep">›</span>
  <span>Ajouter</span>
</nav>

<div class="page-header">
  <h1>Ajouter un auteur</h1>
</div>

<% if (typeof errors !== 'undefined' && errors.length > 0) { %>
  <div class="alert alert-error">⚠️ <%= errors.join(' ') %></div>
<% } %>

<div class="form-card">
  <form action="/auteurs/ajouter" method="POST">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
      <div class="form-group">
        <label class="form-label" for="prenom">Prénom *</label>
        <input class="form-control" type="text" id="prenom" name="prenom"
               value="<%= auteur.prenom || '' %>" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="nom">Nom *</label>
        <input class="form-control" type="text" id="nom" name="nom"
               value="<%= auteur.nom || '' %>" required>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
      <div class="form-group">
        <label class="form-label" for="date_naissance">Date de naissance</label>
        <input class="form-control" type="date" id="date_naissance" name="date_naissance"
               value="<%= auteur.date_naissance || '' %>">
      </div>
      <div class="form-group">
        <label class="form-label" for="nationalite">Nationalité</label>
        <input class="form-control" type="text" id="nationalite" name="nationalite"
               value="<%= auteur.nationalite || '' %>">
      </div>
    </div>

    <div class="form-group">
      <label class="form-label" for="biographie">Biographie</label>
      <textarea class="form-control" id="biographie" name="biographie"
                rows="5"><%= auteur.biographie || '' %></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-gold">✓ Enregistrer</button>
      <a href="/auteurs" class="btn btn-outline">Annuler</a>
    </div>
  </form>
</div>

<%- include('../../partials/footer') %>